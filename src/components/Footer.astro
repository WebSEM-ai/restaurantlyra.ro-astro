---
import { siteConfig } from '../../site.config';
import { translations, type Locale, getLocalePath } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
const t = translations[locale];
---

<footer class="bg-dark text-white/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- About -->
      <div>
        <h3 class="text-xl font-heading font-bold text-white mb-4">{siteConfig.name}</h3>
        <p class="text-sm leading-relaxed">{t.footer.description}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-heading font-semibold text-white mb-4">{t.footer.quickLinks}</h4>
        <nav class="space-y-2">
          <a href={getLocalePath(locale, '/meniu/')} class="block text-sm hover:text-secondary transition-colors">{t.nav.menu}</a>
          <a href={getLocalePath(locale, '/galerie/')} class="block text-sm hover:text-secondary transition-colors">{t.nav.gallery}</a>
          <a href={getLocalePath(locale, '/evenimente/')} class="block text-sm hover:text-secondary transition-colors">{t.nav.events}</a>
          <a href={getLocalePath(locale, '/contact/')} class="block text-sm hover:text-secondary transition-colors">{t.nav.contact}</a>
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-lg font-heading font-semibold text-white mb-4">{t.footer.contactInfo}</h4>
        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>{siteConfig.contact.address}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="hover:text-secondary transition-colors">{siteConfig.contact.phone}</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-secondary transition-colors">{siteConfig.contact.email}</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>{siteConfig.hours.days}: {siteConfig.hours.open}</span>
          </div>
        </div>

        <!-- Social -->
        <div class="mt-6">
          <p class="text-sm font-medium text-white mb-3">{t.common.followUs}</p>
          <div class="flex gap-3">
            {Object.entries(siteConfig.social).map(([platform, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary transition-colors"
                aria-label={platform}
              >
                <span class="text-xs uppercase">{platform.slice(0, 2)}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 text-center text-xs text-white/50">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. {t.common.copyright}</p>
    </div>
  </div>
</footer>
