---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'center' } = Astro.props;
---

<div class:list={['mb-12', align === 'center' ? 'text-center' : 'text-left']}>
  <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mb-4">{title}</h2>
  {subtitle && (
    <p class:list={['text-lg text-dark/60 leading-relaxed', align === 'center' && 'max-w-2xl mx-auto']}>
      {subtitle}
    </p>
  )}
  <div class:list={['mt-4 w-20 h-1 bg-secondary rounded', align === 'center' ? 'mx-auto' : '']} />
</div>
