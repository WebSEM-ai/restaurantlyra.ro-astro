---
import { siteConfig } from '../../site.config';
import { translations, type Locale, getLocalePath } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;
const t = translations[locale];
const currentPath = Astro.url.pathname.replace(/^\/(ro|hu|en)/, '') || '/';
const localeOptions = [
  { code: 'ro', label: 'RO', href: getLocalePath('ro', currentPath) },
  { code: 'hu', label: 'HU', href: getLocalePath('hu', currentPath) },
  { code: 'en', label: 'EN', href: getLocalePath('en', currentPath) },
] as const;

const navLabels = {
  ro: { restaurant: 'Restaurant', delivery: 'Delivery', terrace: 'Terasă', events: 'Evenimente' },
  hu: { restaurant: 'Étterem', delivery: 'Kiszállítás', terrace: 'Terasz', events: 'Rendezvények' },
  en: { restaurant: 'Restaurant', delivery: 'Delivery', terrace: 'Terrace', events: 'Events' },
}[locale];

// Main nav items visible in header bar
const mainNavItems = [
  { label: navLabels.restaurant, href: getLocalePath(locale, '/meniu/') },
  { label: navLabels.delivery, href: getLocalePath(locale, '/delivery/') },
  { label: navLabels.terrace, href: getLocalePath(locale, '/galerie/') },
  { label: 'Catering', href: getLocalePath(locale, '/catering/') },
  { label: navLabels.events, href: getLocalePath(locale, '/evenimente/') },
];

// All nav items for hamburger overlay
const allNavItems = [
  { label: t.nav.home, href: getLocalePath(locale, '/') },
  { label: navLabels.restaurant, href: getLocalePath(locale, '/meniu/') },
  { label: navLabels.delivery, href: getLocalePath(locale, '/delivery/') },
  { label: navLabels.terrace, href: getLocalePath(locale, '/galerie/') },
  { label: 'Catering', href: getLocalePath(locale, '/catering/') },
  { label: navLabels.events, href: getLocalePath(locale, '/evenimente/') },
  { label: t.nav.gallery, href: getLocalePath(locale, '/galerie/') },
  { label: t.nav.contact, href: getLocalePath(locale, '/contact/') },
];
---

<!-- Main Header — transparent, overlays hero -->
<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-header">
  <div class="w-full transition-all duration-500" id="header-inner">
    <div class="w-full px-5 sm:px-8 lg:px-12">
      <div class="flex h-[72px] items-center justify-between sm:h-[90px]">

        <!-- Logo -->
        <a href={getLocalePath(locale, '/')} class="flex items-center shrink-0">
          <img
            src="/images/logo-lyra.png"
            alt={siteConfig.name}
            class="h-[3.6rem] w-auto transition-all duration-300 sm:h-[4.6rem] lg:h-[5rem]"
            id="header-logo"
          />
        </a>

        <!-- Center Nav (desktop) -->
        <nav class="hidden lg:flex items-center gap-1" id="main-nav">
          {mainNavItems.map((item) => (
            <a
              href={item.href}
              class="nav-link px-4 py-2 text-sm font-medium tracking-wide text-white/85 hover:text-white transition-colors duration-300 rounded-lg hover:bg-white/10"
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Right Side Actions -->
        <div class="flex items-center gap-3 sm:gap-4">

          <div class="inline-flex items-center rounded-full border border-white/15 bg-white/8 p-1 backdrop-blur-sm md:hidden">
            {localeOptions.map((option) => (
              <a
                href={option.href}
                aria-current={option.code === locale ? 'page' : undefined}
                class:list={[
                  'inline-flex items-center justify-center rounded-full px-3 py-1.5 text-[0.62rem] font-semibold uppercase tracking-[0.18em] transition-all duration-300',
                  option.code === locale
                    ? 'bg-white/16 text-white shadow-[0_10px_24px_rgba(0,0,0,0.18)]'
                    : 'text-white/68 hover:text-white',
                ]}
              >
                {option.label}
              </a>
            ))}
          </div>

          <!-- Language Switcher -->
          <div
            class="hidden md:inline-flex items-center rounded-full border p-1 transition-all duration-300"
            id="lang-switch"
          >
            {localeOptions.map((option) => (
              <a
                href={option.href}
                aria-current={option.code === locale ? 'page' : undefined}
                class:list={[
                  'lang-option inline-flex items-center justify-center rounded-full px-3.5 py-2 text-[11px] font-semibold tracking-[0.22em] uppercase transition-all duration-300',
                  option.code === locale && 'lang-option-active',
                ]}
              >
                {option.label}
              </a>
            ))}
          </div>

          <!-- Reserve CTA -->
          <a
            href={siteConfig.reservation.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-secondary px-4 py-2.5 text-[0.76rem] font-semibold tracking-wide text-white transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_4px_20px_rgba(233,64,55,0.4)] sm:px-7 sm:py-3 sm:text-sm"
          >
            <span class="relative z-10">{t.common.reserveTable}</span>
            <svg class="relative z-10 w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span class="absolute inset-0 bg-gradient-to-r from-secondary via-[#d4302a] to-secondary bg-[length:200%_100%] group-hover:animate-[shimmer_1.5s_ease-in-out_infinite] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          </a>

          <!-- Hamburger Menu Button -->
          <button
            id="hamburger-btn"
            class="relative flex h-10 w-10 items-center justify-center rounded-full border transition-all duration-300 sm:h-11 sm:w-11"
            aria-label="Toggle menu"
          >
            <div class="hamburger-lines" id="hamburger-lines">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Fullscreen Navigation Overlay -->
<div id="nav-overlay" class="fixed inset-0 z-[55] pointer-events-none opacity-0 transition-opacity duration-500">
  <div class="absolute inset-0 bg-primary/98 backdrop-blur-xl"></div>
  <div class="relative z-10 flex h-full flex-col overflow-y-auto px-6 pb-10 pt-[104px] sm:px-16 sm:pt-[120px] lg:px-24">
    <button
      id="close-nav-overlay"
      type="button"
      class="absolute right-5 top-5 inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/14 bg-white/6 text-white transition-all duration-300 hover:bg-white/12 sm:right-8 sm:top-8"
      aria-label="Close menu"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <!-- Nav Links -->
    <nav class="flex-1 flex flex-col justify-center">
      <ul class="space-y-1">
        {allNavItems.map((item, i) => (
          <li class="nav-reveal" style={`--delay: ${i * 0.06}s`}>
            <a
              href={item.href}
              class="group flex items-center gap-4 py-3 sm:py-4"
            >
              <span class="text-secondary/40 text-xs font-mono tracking-wider">0{i + 1}</span>
              <span class="text-2xl sm:text-4xl lg:text-5xl font-heading font-bold text-white/90 group-hover:text-secondary transition-colors duration-300">
                {item.label}
              </span>
              <svg class="w-5 h-5 sm:w-6 sm:h-6 text-secondary/0 group-hover:text-secondary group-hover:translate-x-1 transition-all duration-300 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Bottom Bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 pt-8 border-t border-white/10">
      <div class="flex items-center gap-6">
        <div class="inline-flex items-center rounded-full border border-white/15 bg-white/6 p-1 backdrop-blur-sm">
          {localeOptions.map((option) => (
            <a
              href={option.href}
              aria-current={option.code === locale ? 'page' : undefined}
              class:list={[
                'inline-flex items-center justify-center rounded-full px-3.5 py-2 text-[11px] font-semibold tracking-[0.22em] uppercase text-white/68 transition-all duration-300 hover:text-white',
                option.code === locale && 'bg-white/14 text-white shadow-[0_10px_24px_rgba(0,0,0,0.18)]',
              ]}
            >
              {option.label}
            </a>
          ))}
        </div>
      </div>

      <a
        href={siteConfig.reservation.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-secondary text-white text-sm font-semibold tracking-wide rounded-full hover:bg-secondary/90 transition-all duration-300 hover:shadow-[0_4px_20px_rgba(233,64,55,0.3)]"
      >
        {t.common.reserveTable}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  /* --- Transparent state (top of page) --- */
  #main-header:not(.header-scrolled) #header-inner {
    background: transparent;
  }

  #main-header:not(.header-scrolled) #hamburger-btn {
    border-color: rgba(255, 255, 255, 0.25);
    color: white;
  }

  #main-header:not(.header-scrolled) #hamburger-btn:hover {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
  }

  #main-header:not(.header-scrolled) #lang-switch {
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
  }

  #main-header:not(.header-scrolled) .lang-option {
    color: rgba(255, 255, 255, 0.7);
  }

  #main-header:not(.header-scrolled) .lang-option:hover {
    color: white;
  }

  #main-header:not(.header-scrolled) .lang-option-active {
    background: rgba(255, 255, 255, 0.18);
    color: white;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }

  /* --- Scrolled state (solid bg) --- */
  .header-scrolled #header-inner {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.08);
  }

  .header-scrolled .nav-link {
    color: rgba(15, 31, 23, 0.7) !important;
  }

  .header-scrolled .nav-link:hover {
    color: rgba(15, 31, 23, 1) !important;
    background: rgba(15, 31, 23, 0.05) !important;
  }

  .header-scrolled #hamburger-btn {
    border-color: rgba(15, 31, 23, 0.15);
    color: var(--color-dark);
  }

  .header-scrolled #hamburger-btn:hover {
    border-color: rgba(26, 58, 42, 0.3);
    background: rgba(26, 58, 42, 0.05);
  }

  .header-scrolled #lang-switch {
    border-color: rgba(15, 31, 23, 0.08);
    background: rgba(15, 31, 23, 0.04);
  }

  .header-scrolled .lang-option {
    color: rgba(15, 31, 23, 0.48);
  }

  .header-scrolled .lang-option:hover {
    color: var(--color-primary);
  }

  .header-scrolled .lang-option-active {
    background: rgba(26, 58, 42, 0.09);
    color: var(--color-primary);
  }

  .header-scrolled #header-logo {
    height: 3.35rem;
  }

  /* --- Hamburger --- */
  .hamburger-lines {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 20px;
  }

  .hamburger-lines span {
    display: block;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .hamburger-lines span:nth-child(1) { width: 100%; }
  .hamburger-lines span:nth-child(2) { width: 66%; margin-left: auto; }
  .hamburger-lines span:nth-child(3) { width: 100%; }

  .hamburger-active .hamburger-lines span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger-active .hamburger-lines span:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .hamburger-active .hamburger-lines span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Nav overlay reveal --- */
  .nav-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: var(--delay, 0s);
  }

  .nav-open .nav-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- Shimmer --- */
  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const navOverlay = document.getElementById('nav-overlay');
  const closeNavOverlayBtn = document.getElementById('close-nav-overlay');
  const mainHeader = document.getElementById('main-header');
  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;

    if (isOpen) {
      navOverlay?.classList.remove('pointer-events-none', 'opacity-0');
      navOverlay?.classList.add('pointer-events-auto', 'opacity-100');
      hamburgerBtn?.classList.add('hamburger-active');
      document.body.style.overflow = 'hidden';
      setTimeout(() => navOverlay?.classList.add('nav-open'), 50);
    } else {
      navOverlay?.classList.remove('nav-open');
      navOverlay?.classList.add('pointer-events-none', 'opacity-0');
      navOverlay?.classList.remove('pointer-events-auto', 'opacity-100');
      hamburgerBtn?.classList.remove('hamburger-active');
      document.body.style.overflow = '';
    }
  }

  hamburgerBtn?.addEventListener('click', toggleMenu);
  closeNavOverlayBtn?.addEventListener('click', () => {
    if (isOpen) toggleMenu();
  });

  navOverlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (isOpen) toggleMenu();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) toggleMenu();
  });

  navOverlay?.addEventListener('click', (e) => {
    if (e.target === navOverlay && isOpen) toggleMenu();
  });

  // Scroll: transparent → solid
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      mainHeader?.classList.add('header-scrolled');
    } else {
      mainHeader?.classList.remove('header-scrolled');
    }
  });
</script>
