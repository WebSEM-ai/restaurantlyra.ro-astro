---
import { siteConfig } from '../../site.config';
import type { Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'ro' } = Astro.props;

const featureDescriptions = {
  ro: {
    chef: 'Rețete românești și transilvănene pregătite cu ingrediente proaspete și gust familiar.',
    terrace: 'Terasă aerisită pentru prânzuri liniștite, seri lungi și mese în aer liber.',
    events: 'Spațiu potrivit pentru aniversări, mese festive și întâlniri private bine organizate.',
    delivery: 'Comenzi rapide pentru acasă sau birou, cu preparatele Lyra trimise direct către tine.',
    catering: 'Meniuri adaptate pentru evenimente, livrate cu prezentare atentă și ritm bun.',
    parking: 'Acces comod și locuri de parcare la îndemână pentru o experiență fără stres.',
    wifi: 'Conexiune rapidă pentru întâlniri relaxate, rezervări și momentele petrecute aici.',
    ac: 'Sală confortabilă și răcoroasă în zilele calde, fără să pierzi din atmosfera elegantă.',
    playground: 'Colț prietenos pentru familii, astfel încât cei mici să se simtă bine la masă.',
  },
  hu: {
    chef: 'Román és erdélyi receptek friss alapanyagokkal, ismerős és gazdag ízekkel elkészítve.',
    terrace: 'Levegős terasz nyugodt ebédekhez, hosszú estékhez és kellemes szabadtéri étkezésekhez.',
    events: 'Ideális helyszín évfordulókhoz, ünnepi vacsorákhoz és jól szervezett magáneseményekhez.',
    delivery: 'Gyors kiszállítás otthonra vagy irodába, hogy a Lyra ízei könnyen megérkezzenek.',
    catering: 'Személyre szabott menük rendezvényekre, gondos tálalással és biztos szervezéssel.',
    parking: 'Kényelmes érkezés és könnyen elérhető parkolás a stresszmentes élményért.',
    wifi: 'Gyors internet kötetlen találkozókhoz, foglalásokhoz és a nálunk töltött időhöz.',
    ac: 'Kellemes, hűvös belső tér a meleg napokon is, az elegáns hangulat megtartásával.',
    playground: 'Családbarát sarok, hogy a gyerekek is jól érezzék magukat az asztalnál.',
  },
  en: {
    chef: 'Romanian and Transylvanian recipes prepared with fresh ingredients and a familiar taste.',
    terrace: 'An airy terrace for relaxed lunches, long evenings, and outdoor meals.',
    events: 'A great space for anniversaries, festive dinners, and well-organized private gatherings.',
    delivery: 'Quick orders for home or office, with Lyra dishes delivered straight to you.',
    catering: 'Custom menus for events, delivered with careful presentation and timing.',
    parking: 'Easy access and convenient parking for a stress-free experience.',
    wifi: 'Fast connection for relaxed meetings, reservations, and time spent here.',
    ac: 'A comfortable, cool space on hot days, without losing the elegant atmosphere.',
    playground: 'A family-friendly corner, so the little ones feel welcome at the table.',
  },
} as const;

const features = siteConfig.features.map((feature, index) => ({
  ...feature,
  title: locale === 'hu' ? feature.nameHu : locale === 'en' ? feature.nameEn : feature.name,
  description: featureDescriptions[locale][feature.icon as keyof typeof featureDescriptions.ro],
  number: String(index + 1).padStart(2, '0'),
}));

const iconPaths: Record<string, string> = {
  chef: 'M12 2C9.24 2 7 4.24 7 7c0 1.64.8 3.09 2.03 4H5v2h14v-2h-4.03A4.98 4.98 0 0017 7c0-2.76-2.24-5-5-5zm0 2c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zM3 15v2h18v-2H3zm2 4v2h14v-2H5z',
  terrace: 'M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3zm0 2.84L18 11v8h-2v-6H8v6H6v-8l6-5.16z',
  events: 'M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z',
  delivery: 'M3 6h11v8H3V6zm12 2h2.5l2.5 3v3h-2a2 2 0 11-4 0H9a2 2 0 11-4 0H3v-2h12V8zm-8 9a1 1 0 100 2 1 1 0 000-2zm9 0a1 1 0 100 2 1 1 0 000-2z',
  catering: 'M8.1 13.34l2.83-2.83L3.91 3.5a4.008 4.008 0 000 5.66l4.19 4.18zm6.78-1.81c1.53.71 3.68.21 5.27-1.38 1.91-1.91 2.28-4.65.81-6.12-1.46-1.46-4.2-1.1-6.12.81-1.59 1.59-2.09 3.74-1.38 5.27L3.7 19.87l1.41 1.41L12 14.41l6.88 6.88 1.41-1.41L13.41 13l1.47-1.47z',
  parking: 'M13 3H6v18h4v-6h3c3.31 0 6-2.69 6-6s-2.69-6-6-6zm.2 8H10V7h3.2c1.1 0 2 .9 2 2s-.9 2-2 2z',
  wifi: 'M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3a4.237 4.237 0 00-6 0zm-4-4l2 2a7.074 7.074 0 0110 0l2-2C15.14 9.14 8.87 9.14 5 13z',
  ac: 'M22 11h-4.17l3.24-3.24-1.41-1.42L15 11h-2V9l4.66-4.66-1.42-1.41L13 6.17V2h-2v4.17L7.76 2.93 6.34 4.34 11 9v2H9L4.34 6.34 2.93 7.76 6.17 11H2v2h4.17l-3.24 3.24 1.41 1.42L9 13h2v2l-4.66 4.66 1.42 1.41L11 17.83V22h2v-4.17l3.24 3.24 1.42-1.41L13 15v-2h2l4.66 4.66 1.41-1.42L17.83 13H22z',
  playground: 'M13 2v8h8c0-4.42-3.58-8-8-8zm6.32 13.89C20.37 14.54 21 12.84 21 11H6.44l-.95-2H2v2h2.22s1.89 4.07 2.12 4.42c-1.1.59-1.84 1.75-1.84 3.08C4.5 20.43 6.07 22 8 22c1.76 0 3.22-1.3 3.46-3h2.08c.24 1.7 1.7 3 3.46 3 1.93 0 3.5-1.57 3.5-3.5 0-1.04-.46-1.97-1.18-2.61zM8 20c-.83 0-1.5-.67-1.5-1.5S7.17 17 8 17s1.5.67 1.5 1.5S8.83 20 8 20zm9 0c-.83 0-1.5-.67-1.5-1.5S16.17 17 17 17s1.5.67 1.5 1.5S17.83 20 17 20z',
};
---

<div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
  {features.map((feature) => (
    <article class="group relative overflow-hidden rounded-[1.75rem] border border-dark/10 bg-white p-6 shadow-[0_18px_50px_rgba(15,31,23,0.07)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,31,23,0.12)]">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-secondary/50 to-transparent"></div>
      <div class="flex items-start justify-between gap-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-primary shadow-inner shadow-primary/10 transition-transform duration-300 group-hover:scale-105">
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d={iconPaths[feature.icon] || iconPaths.chef} />
          </svg>
        </div>
        <span class="text-[11px] font-semibold uppercase tracking-[0.24em] text-dark/30">{feature.number}</span>
      </div>
      <div class="mt-5">
        <h3 class="text-lg font-heading font-bold text-dark">{feature.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-dark/60">{feature.description}</p>
      </div>
      <div class="mt-6 h-1.5 w-14 rounded-full bg-gradient-to-r from-secondary/70 to-secondary/10"></div>
    </article>
  ))}
</div>
