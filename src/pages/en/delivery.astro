---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import DeliveryShowcase from '../../components/DeliveryShowcase.astro';

const locale = 'en';
---

<BaseLayout title="Delivery" locale={locale}>
  <Hero
    title="Lyra Delivery"
    subtitle="Order your favorite dishes for home or office."
    backgroundImage="/images/diverse/diverse-2.webp"
    compact
  />

  <DeliveryShowcase locale={locale} />
</BaseLayout>
