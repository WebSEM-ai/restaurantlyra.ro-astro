---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactForm from '../../components/ContactForm.astro';
import { siteConfig } from '../../../site.config';
import { translations } from '../../i18n/translations';

const locale = 'en';
const t = translations[locale];
const mapUrl = siteConfig.contact.mapEmbedUrl;
const openHoursText = 'Restaurant: Monday - Sunday · 07:00 - 22:00 (last order 21:45)';
const deliveryHoursText = 'Delivery: Monday - Sunday · 10:00 - 22:00';
const contactItems = [
  { label: 'Address', value: siteConfig.contact.address, href: siteConfig.contact.directionsUrl },
  { label: 'Mobile', value: siteConfig.contact.phone, href: `tel:${siteConfig.contact.phone.replace(/\s/g, '')}` },
  { label: 'Landline', value: siteConfig.contact.secondaryPhone, href: `tel:${siteConfig.contact.secondaryPhone.replace(/\s/g, '')}` },
  { label: 'Email', value: siteConfig.contact.email, href: `mailto:${siteConfig.contact.email}` },
  { label: 'SMS Feedback', value: siteConfig.contact.feedbackPhone, href: `tel:${siteConfig.contact.feedbackPhone.replace(/\s/g, '')}` },
];
---

<BaseLayout title={t.contact.title} locale={locale}>
  <Hero title={t.contact.title} subtitle={t.contact.subtitle} backgroundImage="/images/exterior/exterior-3.webp" compact />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-heading font-bold text-dark mb-6">{t.common.reserveTable}</h2>
          <ContactForm locale={locale} />
        </div>
        <div>
          <div class="bg-light rounded-xl p-8 mb-8">
            <h3 class="text-xl font-heading font-semibold text-dark mb-6">{t.footer.contactInfo}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {contactItems.map((item) => (
                <a
                  href={item.href}
                  target={item.href.startsWith('http') ? '_blank' : undefined}
                  rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="rounded-2xl border border-dark/8 bg-white px-5 py-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/30 hover:shadow-[0_16px_35px_rgba(15,31,23,0.08)]"
                >
                  <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-dark/45">{item.label}</p>
                  <p class="mt-2 text-base font-semibold leading-relaxed text-dark">{item.value}</p>
                </a>
              ))}
            </div>
            <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div class="rounded-2xl bg-primary px-5 py-5 text-white">
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-white/60">Restaurant Hours</p>
                <p class="mt-2 text-lg font-semibold">{openHoursText}</p>
              </div>
              <div class="rounded-2xl bg-secondary px-5 py-5 text-white">
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-white/70">Delivery</p>
                <p class="mt-2 text-lg font-semibold">{deliveryHoursText}</p>
              </div>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden h-80 lg:h-[27rem] border border-dark/8">
            <iframe src={mapUrl} width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map"></iframe>
          </div>
          <div class="mt-4 flex justify-end">
            <a
              href={siteConfig.contact.directionsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-dark/10 px-5 py-3 text-sm font-semibold text-dark transition-colors hover:border-secondary/30 hover:text-secondary"
            >
              Open Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
