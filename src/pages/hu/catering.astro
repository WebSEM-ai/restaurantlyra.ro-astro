      'Vegyes bruschetta sült zöldségekkel',
      'Hagyományos sajtos saláta',
      'Mini szendvicsek házi pástétommal',
      'Friss zöldségtál mártásokkal',
    ],
  },
  {
    name: 'Levesek',
    description: 'Hagyományos levesek',
    items: [
      'Pacalleves',
      'Húsgombócleves',
      'Csirkeleves házi cérnametélttel',
      'Szezonális zöldségleves',
      'Gombakrémleves',
    ],
  },
  {
