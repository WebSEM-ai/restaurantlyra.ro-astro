---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import { siteConfig } from '../../../site.config';
import { translations } from '../../i18n/translations';

const locale = 'hu';
const t = translations[locale];
---

<BaseLayout title={t.menu.title} locale={locale}>
  <Hero
    title={t.menu.heroTitle}
    subtitle={t.menu.subtitle}
    backgroundImage="/images/interior/interior-1.webp"
    compact
  />

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-dark">{t.menu.appetizers}</h2>
          <div class="flex-1 h-px bg-dark/10"></div>
        </div>
        <div class="space-y-4">
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Lyra hagyományos tál</p><p class="text-sm text-dark/50">Helyi sajtok, házi felvágottak, savanyúságok, zakuszka</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Bruschetta sült zöldségekkel</p><p class="text-sm text-dark/50">Pirított kenyér, szezonális zöldségek, kecskesajt</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Hagyományos sajtos saláta</p><p class="text-sm text-dark/50">Vegyes zöldek, paradicsom, uborka, telemea sajt</p></div>
        </div>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-dark">{t.menu.soups}</h2>
          <div class="flex-1 h-px bg-dark/10"></div>
        </div>
        <div class="space-y-4">
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Pacalleves</p><p class="text-sm text-dark/50">Hagyományos recept tejföllel és erős paprikával</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Húsgombócleves</p><p class="text-sm text-dark/50">Sertéshússal, friss zöldségekkel és lestyánnal</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Csirkeleves cérnametélttel</p><p class="text-sm text-dark/50">Házi tészta, zöldségek, friss fűszernövények</p></div>
        </div>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" /></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-dark">{t.menu.mainCourse}</h2>
          <div class="flex-1 h-px bg-dark/10"></div>
        </div>
        <div class="space-y-4">
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Hagyományos töltött káposzta</p><p class="text-sm text-dark/50">Káposztában, tejföllel és puliszkával</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Marhapörkölt</p><p class="text-sm text-dark/50">Omlós hús, zöldséges szósz, puliszkával tálalva</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Grillezett mititei</p><p class="text-sm text-dark/50">Hagyományos mititei mustárral és friss kenyérrel</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Grillezett pisztráng</p><p class="text-sm text-dark/50">Friss hal grillezett zöldség körettel</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Sertésszelet</p><p class="text-sm text-dark/50">Grillezve, parasztkrumplival és salátával</p></div>
        </div>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0A1.75 1.75 0 013 15.546" /></svg>
          </div>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-dark">{t.menu.desserts}</h2>
          <div class="flex-1 h-px bg-dark/10"></div>
        </div>
        <div class="space-y-4">
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Papanași tejföllel és lekvárral</p><p class="text-sm text-dark/50">Hagyományos desszert édes tejföllel és gyümölcslekvárral</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Palacsinta lekvárral</p><p class="text-sm text-dark/50">Vékony palacsinta házi lekvárral</p></div>
          <div class="border-b border-dotted border-dark/15 pb-2"><p class="font-semibold text-dark">Kürtőskalács</p><p class="text-sm text-dark/50">Erdélyi specialitás cukorral és fahéjjal</p></div>
        </div>
      </div>

      <div class="bg-light rounded-2xl p-8 text-center">
        <svg class="w-8 h-8 text-secondary mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <p class="text-dark/60">{t.menu.menuNote}</p>
        <a href="/hu/contact/" class="inline-flex items-center gap-2 mt-4 text-primary font-semibold hover:text-secondary transition-colors">
          {t.common.contactUs}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Interior Gallery -->
  <section class="py-20 bg-light/50">
    <div class="w-full px-5 sm:px-8 lg:px-12">
      <div class="text-center mb-14">
        <span class="text-xs tracking-[0.2em] uppercase text-secondary font-semibold">Galéria</span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mt-3">A Belső Tér</h2>
        <div class="mt-4 w-16 h-0.5 bg-secondary/40 mx-auto rounded"></div>
      </div>
      <Gallery images={siteConfig.galleryImages.interior} columns={6} />
    </div>
  </section>
</BaseLayout>
