---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactForm from '../../components/ContactForm.astro';
import { siteConfig } from '../../../site.config';
import { translations } from '../../i18n/translations';

const locale = 'hu';
const t = translations[locale];
const { coordinates } = siteConfig.contact;
const mapUrl = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2700!2d${coordinates.lng}!3d${coordinates.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z!5e0!3m2!1sro!2sro!4v1`;
---

<BaseLayout title={t.contact.title} locale={locale}>
  <Hero title={t.contact.title} subtitle={t.contact.subtitle} backgroundImage="/images/exterior/exterior-3.webp" compact />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-heading font-bold text-dark mb-6">{t.common.reserveTable}</h2>
          <ContactForm locale={locale} />
        </div>
        <div>
          <div class="bg-light rounded-xl p-8 mb-8">
            <h3 class="text-xl font-heading font-semibold text-dark mb-6">{t.footer.contactInfo}</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <div><p class="font-medium text-dark">{t.common.address}</p><p class="text-dark/60">{siteConfig.contact.address}</p></div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <div><p class="font-medium text-dark">{t.common.phone}</p><a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="text-primary hover:text-secondary transition-colors">{siteConfig.contact.phone}</a></div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <div><p class="font-medium text-dark">{t.common.email}</p><a href={`mailto:${siteConfig.contact.email}`} class="text-primary hover:text-secondary transition-colors">{siteConfig.contact.email}</a></div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-secondary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <div><p class="font-medium text-dark">{t.common.openHours}</p><p class="text-dark/60">{siteConfig.hours.days}: {siteConfig.hours.open}</p></div>
              </div>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden h-80">
            <iframe src={mapUrl} width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Térkép"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
