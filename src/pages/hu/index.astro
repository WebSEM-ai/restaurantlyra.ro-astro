---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import Features from '../../components/Features.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTABanner from '../../components/CTABanner.astro';
import { siteConfig } from '../../../site.config';
import { translations } from '../../i18n/translations';

const locale = 'hu';
const t = translations[locale];

const testimonials = [
  { name: 'Kovács M.', text: 'Kiváló ételek! A hagyományos ételek abszolút ízletesek, a légkör pedig meleg és barátságos. Többször visszajöttünk és soha nem csalódtunk.', rating: 5, source: 'Google' },
  { name: 'Nagy A.', text: 'Magánrendezvényt szerveztünk itt és minden tökéletes volt. A menüt személyre szabták, a kiszolgálás kifogástalan. Nagyon ajánlom!', rating: 5, source: 'Facebook' },
  { name: 'Szabó E.', text: 'A legjobb hagyományos étterem Marosvásárhelyen. A levesek fenomenálisak, a töltött káposzta pedig otthoni ízű. A terasz nyáron fantasztikus.', rating: 5, source: 'TripAdvisor' },
];

const previewImages = siteConfig.galleryImages.interior.slice(0, 4);
---

<BaseLayout title={siteConfig.tagline} locale={locale}>
  <Hero
    title="Autentikus erdélyi ízek Marosvásárhely szívében"
    subtitle={t.home.heroSubtitle}
    ctaText={t.common.reserveTable}
    ctaHref="/hu/contact/"
    secondaryCtaText={t.common.viewMenu}
    secondaryCtaHref="/hu/meniu/"
    backgroundImage="/images/exterior/exterior-1.webp"
  />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mb-6">{t.home.planVisit}</h2>
        <p class="text-lg text-dark/60 leading-relaxed mb-8">{t.home.intro}</p>
        <a href="/hu/meniu/" class="inline-flex items-center px-8 py-4 bg-secondary text-white font-semibold rounded-lg hover:bg-secondary/90 transition-colors text-lg">
          {t.common.viewMenu}
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-heading font-bold text-dark">{t.home.features}</h2>
        <div class="mt-4 w-20 h-1 bg-secondary rounded mx-auto" />
      </div>
      <Features locale={locale} />
    </div>
  </section>

  <section class="py-20 bg-dark text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">{t.common.openHours}</h2>
      <div class="mt-8 flex flex-col sm:flex-row gap-8 justify-center text-white/80">
        <div>
          <p class="font-semibold text-secondary">{siteConfig.hours.days}</p>
          <p class="text-2xl font-heading font-bold mt-2">{siteConfig.hours.open}</p>
        </div>
        <div class="hidden sm:block w-px bg-white/20"></div>
        <div>
          <p class="font-semibold text-secondary">Konyha</p>
          <p class="text-2xl font-heading font-bold mt-2">{siteConfig.hours.kitchen}</p>
        </div>
      </div>
      <div class="mt-10">
        <a href="/hu/contact/" class="inline-flex items-center gap-2 px-8 py-4 bg-secondary text-white font-semibold rounded-lg hover:bg-secondary/90 transition-colors text-lg">
          {t.common.reserveTable}
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle title={t.home.galleryPreview} />
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {previewImages.map((img) => (
          <div class="aspect-[4/3] rounded-xl overflow-hidden group">
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/hu/galerie/" class="inline-flex items-center gap-2 text-primary font-semibold hover:text-secondary transition-colors">
          {t.common.viewGallery}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <Testimonials title="Vendégeink Véleménye" testimonials={testimonials} locale={locale} />

  <CTABanner
    title={t.home.cta}
    primaryText={t.common.reserveTable}
    primaryHref="/hu/contact/"
    secondaryText={t.common.contactUs}
    secondaryHref="/hu/contact/"
  />
</BaseLayout>
