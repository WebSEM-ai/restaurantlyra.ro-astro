---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
import { siteConfig } from '../../site.config';
import { translations } from '../i18n/translations';

const locale = 'ro';
const t = translations[locale];

const cateringMenus = [
  {
    name: 'Meniu Aperitive',
    description: 'Ideal pentru cocktail-uri și recepții',
    items: [
      'Platou tradițional Lyra (brânzeturi, mezeluri, murături)',
      'Bruschete asortate cu legume coapte',
      'Salată tradițională cu brânză telemea',
      'Mini tartine cu pateuri de casă',
      'Platou legume proaspete cu dip-uri',
    ],
  },
  {
    name: 'Meniu Supe & Ciorbe',
    description: 'Supe și ciorbe tradiționale',
    items: [
      'Ciorbă de burtă',
      'Ciorbă de perișoare',
      'Supă de pui cu tăiței de casă',
      'Ciorbă de legume de sezon',
      'Supă cremă de ciuperci',
    ],
  },
  {
    name: 'Meniu Principal',
    description: 'Feluri principale pentru evenimente',
    items: [
      'Sarmale tradiționale cu smântână și mămăligă',
      'Tocăniță de vită cu mămăligă',
      'Mici la grătar cu muștar și pâine',
      'Cotlet de porc la grătar cu garnitură',
      'Păstrăv la grătar cu legume',
      'Pulpă de pui dezosată la cuptor',
      'Ciolan de porc la cuptor',
      'Tochitura moldovenească',
    ],
  },
  {
    name: 'Garnituri',
    description: 'Garnituri proaspete și tradiționale',
    items: [
      'Mămăligă tradițională',
      'Cartofi țărănești',
      'Cartofi prăjiți',
      'Orez cu legume',
      'Legume la grătar de sezon',
      'Salată de sezon',
    ],
  },
  {
    name: 'Deserturi',
    description: 'Dulciuri tradiționale',
    items: [
      'Papanași cu smântână și gem',
      'Clătite cu dulceață de casă',
      'Kürtőskalács (cozonac secuiesc)',
      'Prăjitură de casă asortată',
      'Plăcintă cu mere',
    ],
  },
  {
