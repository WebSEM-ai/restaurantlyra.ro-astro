---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Features from '../components/Features.astro';
import HoursShowcase from '../components/HoursShowcase.astro';
import Testimonials from '../components/Testimonials.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../../site.config';
import { translations } from '../i18n/translations';

const locale = 'ro';
const t = translations[locale];

const testimonials = [
  { name: 'Maria P.', text: 'Mâncare excelentă! Preparatele tradiționale sunt absolut delicioase, iar atmosfera este caldă și primitoare. Am revenit de mai multe ori și nu am fost dezamăgiți niciodată.', rating: 5, source: 'Google' },
  { name: 'Andrei D.', text: 'Am organizat o petrecere privată aici și totul a fost perfect. Meniul a fost personalizat, serviciul impecabil. Recomand cu căldură!', rating: 5, source: 'Facebook' },
  { name: 'Elena M.', text: 'Cel mai bun restaurant tradițional din Târgu Mureș. Ciorbele sunt fenomenale, iar sarmale ca la mama acasă. Terasa este un bonus superb vara.', rating: 5, source: 'TripAdvisor' },
];

const previewImages = siteConfig.galleryImages.interior.slice(0, 4);
---

<BaseLayout title={siteConfig.tagline} locale={locale}>
  <!-- Hero Slider -->
  <Hero
    title={siteConfig.tagline}
    subtitle={t.home.heroSubtitle}
    ctaText={t.common.reserveTable}
    ctaHref={siteConfig.reservation.url}
    secondaryCtaText={t.common.viewMenu}
    secondaryCtaHref="/meniu/"
    slides={[
      { image: '/images/exterior/exterior-1.webp', title: 'Savoare transilvăneană autentică', subtitle: 'Restaurant cu bucătărie tradițională în Târgu Mureș' },
      { image: '/images/interior/interior-1.webp', title: 'Bucătărie tradițională românească', subtitle: 'Preparate autentice cu ingrediente proaspete' },
      { image: '/images/catering/catering-4.webp', title: 'Catering pentru orice ocazie', subtitle: 'Meniuri personalizate și prezentare elegantă', position: 'center bottom' },
      { image: '/images/hero/evenimente.webp', title: 'Evenimente de neuitat', subtitle: 'Nunți, botezuri, aniversări și evenimente corporate' },
      { image: '/images/exterior/exterior-10.webp', title: 'Terasă cu atmosferă unică', subtitle: 'Relaxare și savoare în aer liber', position: 'center center' },
    ]}
  />

  <!-- Intro / Our Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mb-6">
          {t.home.planVisit}
        </h2>
        <p class="text-lg text-dark/60 leading-relaxed mb-8">
          {t.home.intro}
        </p>
        <a
          href="/meniu/"
          class="inline-flex items-center px-8 py-4 bg-secondary text-white font-semibold rounded-lg hover:bg-secondary/90 transition-colors text-lg"
        >
          {t.common.viewMenu}
        </a>
      </div>
    </div>
  </section>

  <!-- Our Story + Video -->
  <section class="our-story relative overflow-hidden py-20 sm:py-24 lg:py-28 bg-light/40">
    <div class="our-story-deco our-story-deco--left" aria-hidden="true"></div>
    <div class="our-story-deco our-story-deco--right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:items-center">

        <!-- Story copy -->
        <div class="our-story-copy">
          <div class="flex items-center gap-3 text-secondary">
            <span class="h-px w-10 bg-secondary/60"></span>
            <span class="text-[0.72rem] font-semibold uppercase tracking-[0.32em]">Povestea noastră</span>
          </div>

          <h2 class="our-story-title mt-5 font-heading text-4xl leading-[1.05] text-dark sm:text-5xl lg:text-[3.4rem]">
            Din <span class="our-story-title-accent">2006</span>,<br />
            <em class="our-story-title-italic">cu drag pentru gust.</em>
          </h2>

          <div class="mt-8 space-y-5 text-[1.02rem] leading-[1.78] text-dark/72 sm:text-[1.06rem]">
            <p>
              Totul a început în anul 2006, dintr-o dorință simplă: aceea de a aduce la masă mâncarea pe care o știam de acasă — gătită încet, cu ingrediente alese cu grijă și servită celor dragi ca într-o duminică în familie.
            </p>
            <p>
              Cu 20 de ani de activitate în spate, am construit pas cu pas brandul <em class="our-story-brand">Lyra</em>, cunoscut astăzi în Târgu Mureș și mult dincolo de granițele orașului. Profil tradițional, dar deschis spre rafinamentul gastronomiei moderne — pentru că tradiția trăiește atunci când îndrăznește să se reinventeze.
            </p>
            <p>
              Tehnică de bucătărie contemporană, plating curat, <span class="our-story-underline">ingrediente locale</span> de <span class="our-story-underline">sezon</span>. Tradiția nu înseamnă să stai pe loc — înseamnă să mergi mai departe cu rădăcinile la tine.
            </p>
          </div>

          <!-- Pull quote -->
          <blockquote class="our-story-quote mt-9 border-l-2 border-secondary/70 pl-6 py-1">
            <p class="font-heading text-xl leading-snug text-dark/85 italic sm:text-2xl">
              „Te primim cu zâmbet, te tratăm cu bun-simț și îți oferim o experiență care te va face să te întorci. La Lyra ești <strong class="not-italic font-bold text-dark">oaspete</strong>, nu client."
            </p>
          </blockquote>

          <!-- Location card -->
          <div class="our-story-location mt-9 flex items-start gap-4 rounded-2xl border border-dark/8 bg-white px-5 py-4 shadow-[0_14px_35px_rgba(15,31,23,0.05)] sm:px-6 sm:py-5">
            <div class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-secondary/12 text-secondary">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21s-7-7.16-7-12a7 7 0 1 1 14 0c0 4.84-7 12-7 12Z" />
                <circle cx="12" cy="9" r="2.5" />
              </svg>
            </div>
            <div>
              <span class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-secondary">Ne găsești aici</span>
              <p class="mt-1 text-sm leading-relaxed text-dark/72 sm:text-[0.95rem]">
                Suntem locul potrivit pentru oricine dorește să scape de aglomerația orașului sau este în tranzit. Vă așteptăm în zona <strong class="font-semibold text-dark">Vatman</strong>, la ieșirea din <strong class="font-semibold text-dark">Corunca</strong>, pe drumul către Sighișoara.
              </p>
            </div>
          </div>
        </div>

        <!-- Video on the right -->
        <div class="our-story-video">
          <div class="relative">
            <span class="our-story-video-tag absolute -top-3 left-6 z-20 inline-flex items-center gap-2 rounded-full bg-secondary px-4 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.24em] text-white shadow-lg">
              <span class="h-1.5 w-1.5 rounded-full bg-white animate-pulse"></span>
              Video
            </span>
            <div
              class="our-story-video-frame group relative aspect-[4/5] overflow-hidden rounded-[1.75rem] shadow-[0_30px_60px_-20px_rgba(15,31,23,0.4)] cursor-pointer"
              data-video-teaser
              data-src="/video/lyra.mp4"
            >
              <img
                src="/video/lyra-poster.jpg"
                alt="O privire în Restaurant Lyra"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-b from-black/15 via-black/35 to-black/65 transition-opacity duration-500 group-hover:opacity-90"></div>

              <button
                type="button"
                aria-label="Play video"
                class="absolute inset-0 m-auto flex h-20 w-20 items-center justify-center rounded-full bg-white/95 text-secondary shadow-2xl transition-all duration-300 group-hover:scale-110 group-hover:bg-white sm:h-24 sm:w-24"
              >
                <svg class="h-8 w-8 ml-1 sm:h-10 sm:w-10" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </button>

              <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-7">
                <p class="font-heading text-xl font-bold leading-tight text-white sm:text-2xl">
                  O privire în Restaurant Lyra
                </p>
                <p class="mt-1.5 text-sm text-white/75">
                  Atmosferă, preparate, oaspeți — un scurt preview.
                </p>
              </div>
            </div>
          </div>

          <!-- Stats strip -->
          <div class="our-story-stats mt-6 grid grid-cols-3 gap-3 rounded-2xl border border-dark/8 bg-white/85 p-4 backdrop-blur-sm sm:gap-4 sm:p-5">
            <div class="text-center">
              <div class="font-heading text-2xl font-bold text-secondary sm:text-3xl">20</div>
              <div class="mt-1 text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-dark/55">Ani de tradiție</div>
            </div>
            <div class="text-center border-x border-dark/8">
              <div class="font-heading text-2xl font-bold text-secondary sm:text-3xl">2006</div>
              <div class="mt-1 text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-dark/55">Anul fondării</div>
            </div>
            <div class="text-center">
              <div class="font-heading text-2xl font-bold text-secondary sm:text-3xl">100%</div>
              <div class="mt-1 text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-dark/55">Făcut cu drag</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('[data-video-teaser]').forEach((el) => {
      el.addEventListener('click', () => {
        const src = el.getAttribute('data-src');
        if (!src) return;
        el.innerHTML = `<video class="absolute inset-0 w-full h-full object-cover" controls autoplay playsinline preload="metadata"><source src="${src}" type="video/mp4">Browserul nu suporta video.</video>`;
        const v = el.querySelector('video');
        v?.focus();
      });
    });
  </script>

  <style>
    .our-story-deco {
      position: absolute;
      pointer-events: none;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.45;
      z-index: 0;
    }

    .our-story-deco--left {
      top: -120px;
      left: -120px;
      width: 360px;
      height: 360px;
      background: radial-gradient(circle, rgba(233, 64, 55, 0.18), transparent 70%);
    }

    .our-story-deco--right {
      bottom: -140px;
      right: -140px;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(26, 58, 42, 0.22), transparent 70%);
    }

    .our-story-title-italic {
      font-style: italic;
      font-weight: 600;
      color: var(--color-primary, #1a3a2a);
    }

    .our-story-title-accent {
      color: var(--color-secondary, #e94037);
      font-style: italic;
      font-weight: 700;
    }

    .our-story-brand {
      font-style: italic;
      font-weight: 700;
      color: var(--color-secondary, #e94037);
      letter-spacing: 0.01em;
    }

    .our-story-underline {
      background-image: linear-gradient(transparent 70%, rgba(233, 64, 55, 0.28) 70%);
      background-repeat: no-repeat;
      background-size: 100% 100%;
      padding: 0 0.1em;
    }

    @media (min-width: 1024px) {
      .our-story-video {
        position: sticky;
        top: 120px;
      }
    }
  </style>

  <!-- Features -->
  <section class="py-16 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark">{t.home.features}</h2>
        <p class="mt-4 text-lg leading-relaxed text-dark/60">
          Bucătărie tradițională, spații pentru evenimente și confort real pentru mesele în familie, întâlnirile cu prietenii sau ocaziile speciale.
        </p>
        <div class="mt-5 w-20 h-1 bg-secondary rounded mx-auto" />
      </div>
      <Features locale={locale} />
    </div>
  </section>

  <HoursShowcase locale={locale} />

  <!-- Gallery Preview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle title={t.home.galleryPreview} />
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {previewImages.map((img) => (
          <div class="aspect-[4/3] rounded-xl overflow-hidden group">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/galerie/" class="inline-flex items-center gap-2 text-primary font-semibold hover:text-secondary transition-colors">
          {t.common.viewGallery}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Events Preview -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/catering/catering-1.webp')"></div>
    <div class="absolute inset-0 bg-dark/80"></div>
    <div class="relative z-10 text-center px-5">
      <span class="text-xs tracking-[0.2em] uppercase text-secondary font-semibold">
        {t.home.eventsPreview}
      </span>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mt-3 mb-4">
        {t.events.title}
      </h2>
      <p class="text-white/60 mb-8 max-w-lg mx-auto">
        {t.events.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/evenimente/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-secondary text-white font-semibold rounded-full hover:bg-secondary/90 transition-all duration-300 text-lg"
        >
          {t.common.moreDetails}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 text-white font-semibold rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 text-lg"
        >
          {t.common.contactUs}
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials
    title={locale === 'hu' ? 'Vendégeink Véleménye' : 'Ce Spun Clienții Noștri'}
    testimonials={testimonials}
    locale={locale}
  />

  <!-- CTA Section -->
  <CTABanner
    title={t.home.cta}
    primaryText={t.common.reserveTable}
    primaryHref={siteConfig.reservation.url}
    secondaryText={t.common.contactUs}
    secondaryHref="/contact/"
  />
</BaseLayout>
