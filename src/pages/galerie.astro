---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
import { siteConfig } from '../../site.config';
import { translations } from '../i18n/translations';

const locale = 'ro';
const t = translations[locale];

const allImages = [
  ...siteConfig.galleryImages.interior,
  ...siteConfig.galleryImages.exterior.slice(0, 10),
  ...siteConfig.galleryImages.catering,
  ...siteConfig.galleryImages.diverse,
];
---

<BaseLayout title={t.gallery.title} locale={locale}>
  <Hero
    title={t.gallery.heroTitle}
    subtitle={t.gallery.subtitle}
    backgroundImage="/images/exterior/exterior-10.webp"
    compact
  />

  <!-- Exterior -->
  <section class="py-20 bg-white">
    <div class="w-full px-5 sm:px-8 lg:px-12">
      <div class="text-center mb-14">
        <span class="text-xs tracking-[0.2em] uppercase text-secondary font-semibold">
          {t.gallery.exterior}
        </span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mt-3">
          {locale === 'hu' ? 'Külső Tér és Terasz' : 'Exterior și Terasă'}
        </h2>
        <div class="mt-4 w-16 h-0.5 bg-secondary/40 mx-auto rounded"></div>
      </div>
      <Gallery images={siteConfig.galleryImages.exterior} columns={4} />
    </div>
  </section>

  <!-- Catering & Diverse -->
  <section class="py-20 bg-white">
    <div class="w-full px-5 sm:px-8 lg:px-12">
      <div class="text-center mb-14">
        <span class="text-xs tracking-[0.2em] uppercase text-secondary font-semibold">
          {t.gallery.events}
        </span>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-dark mt-3">
          {locale === 'hu' ? 'Catering és Rendezvények' : 'Catering și Evenimente'}
        </h2>
        <div class="mt-4 w-16 h-0.5 bg-secondary/40 mx-auto rounded"></div>
      </div>
      <Gallery images={[...siteConfig.galleryImages.catering, ...siteConfig.galleryImages.diverse]} columns={3} />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/exterior/exterior-5.webp')"></div>
    <div class="absolute inset-0 bg-dark/80"></div>
    <div class="relative z-10 text-center px-5">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-4">
        {t.home.cta}
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-secondary text-white font-semibold rounded-full hover:bg-secondary/90 transition-all duration-300 text-lg"
        >
          {t.common.reserveTable}
        </a>
        <a
          href="/evenimente/"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 text-white font-semibold rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 text-lg"
        >
          {t.common.moreDetails}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
