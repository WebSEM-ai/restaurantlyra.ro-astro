---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { siteConfig } from '../../site.config';
import { translations } from '../i18n/translations';
import menuData from '../data/menu.json';

const locale = 'ro';
const t = translations[locale];
const orderUrl = siteConfig.delivery?.orderUrl || '#';
---

<BaseLayout title={t.menu.title} locale={locale}>
  <Hero
    title={t.menu.heroTitle}
    subtitle={t.menu.subtitle}
    backgroundImage="/images/interior/interior-1.webp"
    compact
  />

  <!-- Order online banner (top, non-sticky) -->
  <div class="bg-primary text-white">
    <div class="max-w-7xl mx-auto px-5 py-4 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-3">
        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
        <span class="font-medium text-sm sm:text-base">Comandă cu livrare sau ridicare la tine</span>
      </div>
      <a
        href={orderUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-2 bg-secondary text-white rounded-full font-semibold hover:bg-secondary/90 transition-colors text-sm sm:text-base"
      >
        Comandă online
      </a>
    </div>
  </div>

  <!-- Sticky category navigation (more prominent) -->
  <nav class="sticky top-[72px] sm:top-[90px] z-30 bg-light border-b-2 border-secondary/30 shadow-sm">
    <div class="max-w-7xl mx-auto px-3 sm:px-5">
      <ul class="flex gap-2 py-4 overflow-x-auto whitespace-nowrap scrollbar-thin">
        {menuData.categories.map((c) => (
          <li>
            <a
              href={`#${c.slug}`}
              class="cat-link inline-block px-5 py-2.5 text-sm sm:text-base font-semibold text-dark bg-white border border-dark/10 rounded-full transition-all hover:bg-secondary hover:text-white hover:border-secondary hover:shadow-md"
            >
              {c.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Menu sections -->
  <main>
    {menuData.categories.map((cat, idx) => (
      <section id={cat.slug} class:list={["scroll-mt-40 py-14", idx % 2 === 0 ? "bg-white" : "bg-light/60"]}>
        <div class="max-w-5xl mx-auto px-5">
          <header class="mb-10 flex items-center gap-5">
            {cat.image && (
              <div class="hidden sm:block flex-shrink-0 w-20 h-20 rounded-2xl overflow-hidden bg-light">
                <img src={cat.image} alt={cat.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
            )}
            <div>
              <p class="text-[0.7rem] tracking-[0.2em] uppercase text-secondary font-semibold mb-2">Categorie</p>
              <h2 class="text-2xl sm:text-3xl font-heading font-bold text-dark leading-tight">{cat.title}</h2>
              <div class="mt-3 w-12 h-0.5 bg-secondary/40 rounded"></div>
            </div>
          </header>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-2">
            {cat.items.map((item) => (
              <article class="flex gap-4 py-5 border-b border-dark/10">
                {item.image ? (
                  <div class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-xl overflow-hidden bg-light">
                    <img src={item.image} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                ) : (
                  <div class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-xl bg-light/60 flex items-center justify-center">
                    <svg class="w-8 h-8 text-dark/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 14l2-2m0 0l7-7 7 7M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7m-9 4h2" /></svg>
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex items-start gap-3 justify-between">
                    <h3 class="font-semibold text-dark text-base leading-snug">{item.name}</h3>
                    <span class="text-base font-bold text-primary whitespace-nowrap pt-0.5">
                      {item.price} <span class="text-xs font-medium text-dark/60">lei</span>
                    </span>
                  </div>
                  {item.description && (
                    <p class="mt-1.5 text-sm text-dark/55 leading-relaxed">{item.description}</p>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}
  </main>

  <!-- Footer CTA -->
  <section class="relative py-20 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/interior/interior-2.webp')"></div>
    <div class="absolute inset-0 bg-dark/85"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-4">
        Vino la Restaurant Lyra
      </h2>
      <p class="text-white/70 mb-8 text-base sm:text-lg">
        Rezervă o masă sau comandă online pentru livrare.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-secondary text-white font-semibold rounded-full hover:bg-secondary/90 transition-all duration-300"
        >
          {t.common.reserveTable}
        </a>
        <a
          href={orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white/10 backdrop-blur text-white font-semibold rounded-full border border-white/30 hover:bg-white/20 transition-all duration-300"
        >
          Comandă online
        </a>
      </div>
    </div>
  </section>

  <script>
    // Smooth scroll for category nav
    document.querySelectorAll('nav a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const href = (a as HTMLAnchorElement).getAttribute('href');
        if (!href || href === '#') return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', href);
        }
      });
    });
  </script>
</BaseLayout>
